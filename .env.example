# ════════════════════════════════════════════════════════════
#  HuwaControl — Configuration
#  Copiez ce fichier : cp .env.example .env
#  Puis modifiez les valeurs ci-dessous
# ════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=huwacontrol
POSTGRES_USER=huwa
POSTGRES_PASSWORD=changeme_strong_password

# ── Flask ────────────────────────────────────────────────────
# Générer une clé aléatoire : openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# ── Réseau ───────────────────────────────────────────────────
# Port HTTP exposé par Nginx
HTTP_PORT=8080

# ── Syslog (optionnel) ───────────────────────────────────────
# Port UDP exposé sur l'hôte pour recevoir les syslogs du routeur
# Le conteneur écoute toujours sur 1514 en interne
# SYSLOG_HOST_PORT=514

# ── SNMP Trap (optionnel) ────────────────────────────────────
# Port UDP pour recevoir les traps SNMP
# SNMP_TRAP_PORT=1162
